# Yandex MCP Server Configuration
# Copy this file to .env and fill in your values
# (or set these variables in your MCP client config — Claude Desktop / Claude Code)

# =============================================================================
# Option 1 (recommended): MULTI-ACCOUNT for Yandex DIRECT + WORDSTAT
# =============================================================================
# A JSON object mapping account names to credentials. Pass `account="<name>"`
# parameter to direct_*/wordstat_* MCP tools to choose which account it
# operates on. If `account` is omitted, the FIRST account in the dict is used.
#
# Per-account fields:
#   direct_token   (required) — OAuth token for Yandex Direct API (also Wordstat)
#   client_login   (optional) — Client-Login header value for agency scenarios
#   use_sandbox    (optional) — bool, default false
#
# Example with two accounts:
#
# YANDEX_ACCOUNTS='{
#   "main":      { "direct_token": "y0__...", "client_login": "your-login-1" },
#   "secondary": { "direct_token": "y0__...", "client_login": "your-login-2" }
# }'
#
# Tip: account names are arbitrary keys you choose; use whatever's
# meaningful in your project (e.g. "team_a"/"team_b", "prod"/"test").
#
# Metrika is NOT per-account — it always uses YANDEX_METRIKA_TOKEN (or
# YANDEX_TOKEN). Set it below regardless of which mode you're using.
# YANDEX_METRIKA_TOKEN=your_metrika_oauth_token_here
#
# AppMetrica is also single-token. Token resolution priority:
#   YANDEX_APPMETRICA_TOKEN → YANDEX_METRIKA_TOKEN → YANDEX_TOKEN
# Yandex.Metrica-family tokens usually work for BOTH Metrika and AppMetrica
# (verified empirically), so if you already set YANDEX_METRIKA_TOKEN you
# typically don't need a separate AppMetrica token. Set this variable only
# if you want a different token for AppMetrica.
# Like Metrika, AppMetrica tools do NOT take an `account` parameter.
# YANDEX_APPMETRICA_TOKEN=your_appmetrica_oauth_token_here

# =============================================================================
# Option 2 (legacy): single-account env (backward compatible)
# =============================================================================
# If YANDEX_ACCOUNTS is unset, these variables are collapsed into one virtual
# "default" account. All tool calls without an explicit `account` parameter
# will use it. Useful for upgrades — existing single-account setups keep
# working without any changes.

# Single OAuth token for both services
# This token must have access to both Yandex Direct and Yandex Metrika
YANDEX_TOKEN=your_oauth_token_here

# Optional: separate tokens for each service
# YANDEX_DIRECT_TOKEN=your_direct_token_here
# YANDEX_METRIKA_TOKEN=your_metrika_token_here
# YANDEX_APPMETRICA_TOKEN=your_appmetrica_token_here

# Client login for agency accounts (optional)
# Required when managing campaigns for clients as an agency
# YANDEX_CLIENT_LOGIN=client_login

# Use Yandex Direct Sandbox for testing (optional)
# Set to "true" to use sandbox environment
# YANDEX_USE_SANDBOX=false
